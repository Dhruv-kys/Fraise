{
  "mcpServers": {
    "calculator": {
      "type": "builtin",
      "module": "app.servers.calculator",
      "attr": "mcp"
    },
    "calendar": {
      "type": "builtin",
      "module": "app.servers.calendar",
      "attr": "mcp",
      "disabled": true
    },
    "memory": {
      "type": "builtin",
      "module": "app.servers.memory",
      "attr": "mcp"
    },
    "rag": {
      "type": "builtin",
      "module": "app.servers.rag",
      "attr": "mcp"
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/dhruvdiwakirti/Fraise-files"]
    },
    "web-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
    }
  }
}
